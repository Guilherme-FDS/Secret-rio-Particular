# ── Claude / Anthropic ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Groq (transcrição de áudio Whisper) ──────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Evolution API (WhatsApp) ──────────────────────────────────────────────
EVOLUTION_API_KEY=sua-chave-evolution-aqui

# ── n8n ───────────────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=troque-esta-senha
N8N_ENCRYPTION_KEY=chave-aleatoria-32-chars-minimo

# ── Google (Calendar + Drive + Gmail) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_ADDRESS=guilhermefaustino0402@gmail.com

# ── SSH (acesso ao PC desktop para deploy) ───────────────────────────────
# Opção A — acesso local (n8n e projetos no mesmo PC):
#   SSH_HOST=host-gateway  (resolve automaticamente para o host Windows)
# Opção B — acesso remoto via Tailscale:
#   SSH_HOST=100.x.x.x  (IP Tailscale do PC desktop)
SSH_HOST=host-gateway
SSH_USER=Guilherme Silva

# ── Tailscale (opcional — ativa o sidecar para acesso remoto) ────────────
# Gera em: https://login.tailscale.com/admin/settings/keys
# Deixe vazio para usar só acesso local (SSH_HOST=host-gateway)
TAILSCALE_AUTHKEY=

# ── WhatsApp — seu número para notificações proativas ────────────────────
MEU_NUMERO=5544999999999

# ── n8n Webhook (preenchido após subir o container) ──────────────────────
N8N_WEBHOOK_URL=http://localhost:8080/webhook
